DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=
DISCORD_DRIVER_USER_ID=

# Python service base URL. The bridge expects JSON APIs under this base.
PYTHON_SERVICE_URL=http://127.0.0.1:8001
PYTHON_SERVICE_TOKEN=

# Optional behavior.
COMMAND_REGISTER_SCOPE=guild
JOB_POLL_INTERVAL_MS=1000
STATUS_POLL_TIMEOUT_MS=3000
DEFAULT_ENGINEER_MUTED=false
DEFAULT_AUDIO_MODE=quiet_driver
AUTO_JOIN_ON_READY=false
RECEIVE_WATCHDOG_MS=120000

# Optional live speech-to-text forwarding. Python STT must also be enabled.
DISCORD_STT_ENABLED=false
DISCORD_STT_MIN_SEGMENT_MS=450
DISCORD_STT_MAX_SEGMENT_MS=6000
DISCORD_STT_SAMPLE_RATE=48000
DISCORD_STT_CHANNELS=2
LOG_LEVEL=info
