DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=
DISCORD_DRIVER_USER_ID=

# Python service base URL. The bridge expects JSON APIs under this base.
PYTHON_SERVICE_URL=http://127.0.0.1:8000
PYTHON_SERVICE_TOKEN=

# Optional behavior.
COMMAND_REGISTER_SCOPE=guild
JOB_POLL_INTERVAL_MS=1000
STATUS_POLL_TIMEOUT_MS=3000
DEFAULT_ENGINEER_MUTED=false
DEFAULT_AUDIO_MODE=quiet_driver
AUTO_JOIN_ON_READY=false
LOG_LEVEL=info
