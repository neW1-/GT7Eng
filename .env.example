# Python service
GT7ENG_HOST=0.0.0.0
GT7ENG_PORT=8001
GT7ENG_PRESET=endurance
GT7ENG_VOICE_MODE=quiet_driver_ai
GT7ENG_WAKE_PHRASE=engineer
GT7ENG_POSITION_COALESCE_SECONDS=1.5
GT7ENG_STT_ENABLED=false
GT7ENG_STT_MODEL=base.en
GT7ENG_STT_DEVICE=cpu
GT7ENG_STT_MIN_CONFIDENCE=0.45
GT7ENG_LLM_BASE_URL=http://127.0.0.1:8000/v1
GT7ENG_LLM_MODEL=gemma-4-e4b-it-4bit
GT7ENG_LLM_API_KEY=
GT7ENG_LLM_TIMEOUT=20
GT7ENG_LLM_MAX_TOKENS=80
GT7ENG_LLM_DISABLE_THINKING=true
GT7ENG_LLM_INTENT_REPAIR=true
GT7ENG_LLM_INTENT_REPAIR_MIN_CONFIDENCE=0.55

# Optional BLE pixel gear indicator
GT7ENG_PIXEL_DISPLAY_ENABLED=false
GT7ENG_PIXEL_DISPLAY_ADDRESS=
GT7ENG_PIXEL_DISPLAY_UPDATE_HZ=10
GT7ENG_PIXEL_DISPLAY_REV_POSITION=bottom
GT7ENG_PIXEL_DISPLAY_BRIGHTNESS=60
GT7ENG_PIXEL_DISPLAY_DIM_BRIGHTNESS=12
GT7ENG_PIXEL_DISPLAY_ORIENTATION=0
GT7ENG_PIXEL_DISPLAY_SHIFT_PERCENT=0.96
GT7ENG_PIXEL_DISPLAY_FLASH_HZ=8
GT7ENG_PIXEL_DISPLAY_COLOR_THEME=simdt_blue
GT7ENG_PIXEL_DISPLAY_GEAR_COLOR=
GT7ENG_PIXEL_DISPLAY_REV_LOW_COLOR=
GT7ENG_PIXEL_DISPLAY_REV_MID_COLOR=
GT7ENG_PIXEL_DISPLAY_REV_HIGH_COLOR=
GT7ENG_PIXEL_DISPLAY_SHIFT_COLOR=
GT7ENG_PIXEL_DISPLAY_RPM_MIN=
GT7ENG_PIXEL_DISPLAY_RPM_MAX=

# Optional manual PS5 fallback. Leave blank for auto-discovery.
GT7ENG_PS_IP=

# Discord bridge
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_VOICE_CHANNEL_ID=
DISCORD_DRIVER_USER_ID=
GT7ENG_API_URL=http://localhost:8001
PYTHON_SERVICE_URL=http://localhost:8001
DEFAULT_AUDIO_MODE=quiet_driver_ai
AUTO_JOIN_ON_READY=true
DISCORD_STT_ENABLED=false
